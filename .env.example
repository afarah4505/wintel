# Solana RPC
# For full wallet history (age, first tx), use a free Helius RPC:
# Sign up at https://dev.helius.xyz → copy your RPC URL → paste below
# Example: https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
# Falls back to public RPC (limited to ~2 months of tx history without a key)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Supabase (optional for watchlist sync)
# Use project root URL, not /rest/v1 (script normalizes but root URL is preferred)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
